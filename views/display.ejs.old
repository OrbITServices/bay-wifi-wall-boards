<!doctype html><html><head><meta charset="utf-8"><title><%= settings.site_name || 'Bay WiFi Wall Boards' %></title><meta name="viewport" content="width=device-width, initial-scale=1"></head><body><div class="screen" data-weather-location="<%= settings.weather_location || 'Tenby' %>" style="--bg:<%= settings.background || '#07111f' %>;--text:<%= settings.text_colour || '#ffffff' %>;--accent:<%= settings.accent_colour || '#2fb5df' %>;"><header class="header"><img class="logo" src="<%= brandLogo %>"><div class="top-info"><div class="date" id="date">Loading date</div><div class="time-weather"><div class="time" id="time">--:--</div><div class="weather"><span id="weather-icon">⛅</span><span id="weather-temp">--°C</span><span id="weather-label">Loading weather</span></div></div></div></header><% pages.forEach(page => { %><section class="slide" data-duration="<%= Math.max(3, page.duration || 15) * 1000 %>"><div class="media"><% if (page.media_url) { %><% if (page.is_video) { %><video src="<%= page.media_url %>" muted loop playsinline></video><% } else { %><img src="<%= page.media_url %>"><% } %><% } else { %><div class="holding"><div class="pattern"></div><img class="holding-logo" src="<%= brandLogo %>"><div class="holding-icon"><%= page.page_type === 'wifi' ? 'WiFi' : page.page_type === 'map' ? 'Map' : page.page_type === 'emergency' ? 'SOS' : page.page_type === 'events' ? 'Events' : 'Info' %></div><h3><%= page.title %></h3><p><%= page.subtitle %></p><span></span></div><% } %></div><div class="content"><div class="content-centre"><span class="label"><%= page.label || 'Guest Information' %></span><h1><%= page.title %></h1><% if (page.subtitle) { %><h2><%= page.subtitle %></h2><% } %><div class="text"><% page.body_lines.forEach(line => { %><p><%= line %></p><% }) %></div></div><% if (page.qr_image) { %><div class="qr-box"><img class="qr" src="<%= page.qr_image %>"><div><h3><%= page.qr_label || (page.page_type === 'wifi' ? 'Scan to Connect' : 'Scan QR Code') %></h3><% if (page.page_type === 'wifi') { %><p><strong>Network:</strong> <%= page.ssid %></p><% if (page.wifi_security !== 'nopass') { %><p><strong>Password:</strong> <%= page.wifi_password %></p><% } else { %><p><strong>Open WiFi network</strong></p><% } %><% } else { %><p>Scan with your phone for more information.</p><% } %></div></div><% } %></div></section><% }) %><% if (settings.footer) { %><footer class="footer"><%= settings.footer %></footer><% } %><% if (settings.ticker) { %><div class="ticker"><span><%= settings.ticker %></span></div><% } %></div><style>html,body{margin:0;padding:0;background:#000}*{box-sizing:border-box}.screen{position:fixed;inset:0;width:100vw;height:100vh;overflow:hidden;background:radial-gradient(circle at top left,rgba(255,255,255,.12),transparent 35%),radial-gradient(circle at bottom right,rgba(255,255,255,.08),transparent 40%),var(--bg);color:var(--text);font-family:Arial,Helvetica,sans-serif;opacity:0;transition:opacity .25s ease}.screen.ready{opacity:1}.header{position:absolute;top:28px;left:40px;right:40px;height:82px;display:flex;justify-content:space-between;align-items:flex-start;z-index:5}.logo{max-height:76px;max-width:300px;object-fit:contain}.top-info{display:flex;flex-direction:column;align-items:flex-end;gap:8px;text-align:right}.date{font-size:22px;font-weight:600;opacity:.9}.time-weather{display:flex;align-items:center;gap:16px}.time{font-size:34px;font-weight:800;color:var(--accent)}.weather{display:flex;align-items:center;gap:9px;background:rgba(255,255,255,.10);border:1px solid rgba(255,255,255,.14);border-radius:18px;padding:9px 14px;white-space:nowrap}.weather span{font-size:18px}#weather-icon{font-size:28px}#weather-temp{font-size:25px;font-weight:800;color:var(--accent)}.slide{display:none;width:100%;height:100%;grid-template-columns:55% 45%;align-items:stretch;gap:50px;padding:130px 60px 105px}.slide.active{display:grid;animation:fade .6s ease}@keyframes fade{from{opacity:0;transform:scale(1.02)}to{opacity:1;transform:scale(1)}}.media img,.media video{width:100%;height:72vh;object-fit:contain;border-radius:28px;background:rgba(0,0,0,.35);box-shadow:0 30px 80px rgba(0,0,0,.35)}.holding{height:72vh;border-radius:28px;position:relative;overflow:hidden;background:linear-gradient(135deg,rgba(255,255,255,.14),rgba(255,255,255,.03)),rgba(0,0,0,.22);border:1px solid rgba(255,255,255,.16);box-shadow:0 30px 80px rgba(0,0,0,.35);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:50px;text-align:center}.pattern{position:absolute;inset:0;background-image:linear-gradient(45deg,rgba(255,255,255,.06) 25%,transparent 25%),linear-gradient(-45deg,rgba(255,255,255,.04) 25%,transparent 25%);background-size:80px 80px;opacity:.45}.holding-logo{position:absolute;top:35px;left:35px;max-width:220px!important;max-height:80px!important;box-shadow:none!important;background:transparent!important}.holding-icon{width:190px;height:190px;border-radius:50%;border:3px solid var(--accent);color:var(--accent);display:flex;align-items:center;justify-content:center;font-size:34px;font-weight:700;margin-bottom:35px;position:relative;z-index:2;background:rgba(0,0,0,.25)}.holding h3{font-size:52px;line-height:1.05;margin:0 0 18px;position:relative;z-index:2}.holding p{font-size:28px;opacity:.85;margin:0;position:relative;z-index:2}.holding span{width:140px;height:8px;border-radius:99px;display:block;margin-top:35px;position:relative;z-index:2;background:var(--accent)}.content{background:rgba(255,255,255,.09);backdrop-filter:blur(8px);padding:44px;border-radius:32px;border:1px solid rgba(255,255,255,.14);box-shadow:0 25px 70px rgba(0,0,0,.25);height:72vh;display:flex;flex-direction:column;text-align:center}.content-centre{margin:auto 0;width:100%}.label{display:inline-block;color:var(--accent);font-size:18px;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:18px}.content h1{font-size:54px;line-height:1.05;margin:0 0 16px}.content h2{font-size:28px;margin:0 0 26px;color:var(--accent);font-weight:500}.text p{font-size:25px;line-height:1.32;margin:0 0 14px}.qr-box{display:grid;grid-template-columns:180px 1fr;gap:24px;align-items:center;margin-top:auto;background:rgba(0,0,0,.25);border:1px solid rgba(255,255,255,.14);border-radius:24px;padding:22px;text-align:left}.qr{width:180px!important;height:180px!important;background:#fff!important;padding:10px;border-radius:16px!important;object-fit:contain!important;box-shadow:none!important}.qr-box h3{font-size:30px;margin:0 0 12px;color:var(--accent)}.qr-box p{font-size:23px;margin:8px 0}.footer{position:absolute;left:40px;right:40px;bottom:44px;text-align:center;font-size:22px;opacity:.8;z-index:5}.ticker{position:absolute;left:0;right:0;bottom:0;height:34px;background:rgba(0,0,0,.35);border-top:1px solid rgba(255,255,255,.12);overflow:hidden;z-index:6;display:flex;align-items:center}.ticker span{white-space:nowrap;display:inline-block;padding-left:100%;animation:none;font-size:18px;opacity:.9}@keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-100%)}}</style><script>document.addEventListener('DOMContentLoaded',function(){const screen=document.querySelector('.screen');const slides=document.querySelectorAll('.slide');let current=0;let timer=null;requestAnimationFrame(()=>screen.classList.add('ready'));function showSlide(index){slides.forEach(slide=>{slide.classList.remove('active');slide.querySelectorAll('video').forEach(video=>{try{video.pause();video.currentTime=0}catch(e){}})});const active=slides[index];if(!active)return;active.classList.add('active');active.querySelectorAll('video').forEach(video=>{try{video.play()}catch(e){}});const duration=parseInt(active.dataset.duration||15000);clearTimeout(timer);timer=setTimeout(()=>{current=(current+1)%slides.length;showSlide(current)},duration)}function getOrdinal(day){if(day>3&&day<21)return'th';switch(day%10){case 1:return'st';case 2:return'nd';case 3:return'rd';default:return'th'}}function updateTimeAndDate(){const now=new Date();const t=document.getElementById('time');const d=document.getElementById('date');if(t)t.textContent=now.toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'});if(d){const weekday=now.toLocaleDateString('en-GB',{weekday:'long'});const month=now.toLocaleDateString('en-GB',{month:'long'});const day=now.getDate();const year=now.getFullYear();d.textContent=weekday+' '+day+getOrdinal(day)+' '+month+' '+year}}function getWeatherIcon(condition){const text=String(condition||'').toLowerCase();if(text.includes('thunder'))return'⛈️';if(text.includes('snow')||text.includes('sleet'))return'❄️';if(text.includes('rain')||text.includes('drizzle')||text.includes('shower'))return'🌧️';if(text.includes('fog')||text.includes('mist'))return'🌫️';if(text.includes('cloud')||text.includes('overcast'))return'☁️';if(text.includes('sun')||text.includes('clear'))return'☀️';return'⛅'}function updateWeather(){const location=screen.dataset.weatherLocation||'Tenby';fetch('https://wttr.in/'+encodeURIComponent(location)+'?format=j1').then(r=>r.json()).then(data=>{const currentWeather=data.current_condition[0];const description=currentWeather.weatherDesc[0].value;document.getElementById('weather-icon').textContent=getWeatherIcon(description);document.getElementById('weather-temp').textContent=currentWeather.temp_C+'°C';document.getElementById('weather-label').textContent=description}).catch(()=>{document.getElementById('weather-icon').textContent='⛅';document.getElementById('weather-temp').textContent='--°C';document.getElementById('weather-label').textContent='Weather unavailable'})}if(slides.length)showSlide(current);updateTimeAndDate();updateWeather();setInterval(updateTimeAndDate,30000);setInterval(updateWeather,1800000)});</script></body></html>
